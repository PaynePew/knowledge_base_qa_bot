# Copy this file to .env and fill in your key:  cp .env.example .env

# Required — both stacks call OpenAI to write the final grounded answer.
OPENAI_API_KEY=sk-...

# Optional — only the eval Claude judge (L2 spot-check) uses this.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional — Wiki/BM25 relevance gate (default 0.5). Read once at startup; restart to apply.
# KB_SCORE_THRESHOLD=0.5

# Optional — C5 contradiction audit scaling (full POST /wiki/lint). Read per request.
# Cap on candidate page-pairs sent to the LLM judge, ranked by similarity (default 30).
# KB_LINT_C5_MAX_PAIRS=30
# Bounded concurrency for those LLM calls (default 5).
# KB_LINT_C5_CONCURRENCY=5

# --- Transcribe (issue #426, ADR-0032) — model-assisted PDF conversion ---
# Opt-in even with a valid OPENAI_API_KEY present: the probe-routed
# auto-transcription inside POST /import / kb import only fires when this is
# explicitly set (a bare `git pull` never starts billing your OpenAI account).
# The force entry (POST /transcribe, kb transcribe) also requires this.
# KB_TRANSCRIBE_ENABLED=true
# Optional — model for page transcription. Falls back to OPENAI_MODEL, then
# gpt-5-mini. Read at call time (no restart needed).
# OPENAI_TRANSCRIBE_MODEL=gpt-5-mini
# Optional — page-count cap, checked before any model call (default 50).
# KB_TRANSCRIBE_MAX_PAGES=50

# --- Gateway startup warmup (issue #439) — post-deploy /chat cold start ---
# Opt-in even with a valid OPENAI_API_KEY present: unset/false makes Gateway
# startup fire ZERO OpenAI calls (the reset workflow's default). When true,
# Gateway startup fires one tiny embeddings ping and one tiny LLM ping per
# distinct client (wiki/RAG/Hybrid LLM + RAG/Hybrid embeddings — 5 total) to
# prime connections, so the first real /chat per stack does not pay cold-client
# latency. A few tokens per boot. Read at call time (no restart needed to
# flip). Set to true in docker-compose.prod.yml for the deployed tenant.
# KB_WARMUP_PING=true

# --- Gateway production overload + cost protection (issue #269) ---
# Single worker only (in-process counters/semaphores). Read once at startup;
# restart to apply.

# Optional — max concurrent READ (answer) requests over {/chat/stream,/wiki/chat,
# /rag/chat}. Over-limit → 503; read saturation drives GET /healthz/shed. (default 6)
# KB_MAX_INFLIGHT=6
# Optional — max concurrent ADMIN/index/mutating requests over {/rag/index,
# /wiki/index,/wiki/ingest,/wiki/lint,/wiki/import,/wiki/transcribe,/upload}.
# Over-limit → 503. (default 2)
# KB_MAX_ADMIN=2
# Optional — daily USD ceiling for heavy (OpenAI-calling) requests, accumulated
# per UTC day from a CONSERVATIVE per-endpoint estimate. At cap → 503
# {"detail":"daily demo budget reached"}; resets at UTC midnight. (default 3.0)
# KB_DAILY_USD_CAP=3.0
# Optional — per-page USD charge for Transcribe (issue #460): /wiki/import's
# auto-route and /wiki/transcribe charge page_count * this rate into the SAME
# daily ledger above, checked BEFORE any vision-model call for that file (a
# batch already at the cap is rejected before spending further). Overestimate
# of the real ~$0.002/page (gpt-5-mini, ADR-0032). (default 0.01)
# KB_TRANSCRIBE_PAGE_USD=0.01
# Optional kill-switch — when SET, the admin/index/mutating endpoints require
# Authorization: Bearer <token> (401 otherwise). When UNSET (the demo default)
# those endpoints stay open so the Console works unauthenticated.
# KB_ADMIN_TOKEN=
