# Normalize all text files to LF in the repo and on checkout for every OS.
# This makes diffs and CI behaviour consistent across Windows / macOS / Linux.
* text=auto eol=lf

# Explicit text types (defensive — same effect as the default above, but
# documents intent and survives editors that misdetect file type).
*.py    text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.sh    text eol=lf

# Windows-only scripts must stay CRLF or cmd.exe / PowerShell will misparse.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary — never touch, never diff as text.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tgz   binary
*.whl   binary
*.faiss binary
