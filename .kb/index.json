    {
      "id": "expedited-shipping#expedited-shipping",
      "file": "expedited-shipping",
      "heading": "Expedited Shipping",
      "heading_path": [
        "Expedited Shipping"
      ],
      "content": "Expedited shipping offers a delivery timeframe of 1-2 business days. It is important to note that any fees associated with expedited shipping are non-refundable once the package has been shipped.\n\n[Source: shipping_faq.md#expedited-shipping]",
