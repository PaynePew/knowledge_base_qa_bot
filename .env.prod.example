# Production env template for the VPS deploy (tenant `ask-wiki-rag`, issue #270).
# Copy to `.env.prod`, fill in the secrets, and pass it at run time:
#   docker run --env-file .env.prod -p <host>:8000 <image>
# `.env.prod` is gitignored AND .dockerignored — secrets never get baked into the
# image or committed.

# --- Required ----------------------------------------------------------------

# Both stacks call OpenAI to write the final grounded answer. Use a DEDICATED key
# scoped to this deploy with a hard monthly cap of <= $15/mo set in the OpenAI
# dashboard — so a runaway loop can't drain the main account.
OPENAI_API_KEY=

# --- Cost + concurrency guardrails -------------------------------------------

# Daily spend ceiling (USD). The Gateway refuses heavy (OpenAI-calling) requests
# with HTTP 503 {"detail":"daily demo budget reached"} once the UTC-day estimated
# cost reaches this; the accumulator resets at UTC midnight.
KB_DAILY_USD_CAP=3

# Max concurrent in-flight /chat requests (back-pressure for the single worker).
KB_MAX_INFLIGHT=6

# Max concurrent admin/index operations (separate, smaller pool — these are heavy).
KB_MAX_ADMIN=2

# --- Read-reserved budget + per-IP rate limit (issue #598 Slice A) -----------
# Floor of KB_DAILY_USD_CAP that admin/mutating paths cannot spend into — the
# read/chat path always keeps this much headroom even if admin traffic alone
# would otherwise exhaust the cap. (default 1.0)
# KB_READ_RESERVED_USD=1.0
# Per-IP fixed-window limit (5 min, not configurable) over every heavy path.
# Over-limit → 429, checked before the concurrency semaphore/budget charge.
# `0` disables. (default 30)
# KB_RATE_LIMIT_PER_IP=30

# --- SSE slow-client capacity (issue #599) ------------------------------------
# A held-open /chat/stream connection occupies a slot for the full stream
# duration (seconds), so a dedicated cap protects capacity independently of
# KB_MAX_INFLIGHT above. Defaults (6 / 15s / 45s) are conservative; uncomment
# to override.
# KB_SSE_MAX_CONCURRENT=6
# KB_SSE_HEARTBEAT_INTERVAL_SEC=15
# KB_SSE_IDLE_TIMEOUT_SEC=45

# --- Optional ----------------------------------------------------------------

# Bearer token gating the admin surface (index/upload/lint). Leave blank to keep
# admin endpoints open (only safe behind a trusted reverse proxy / private net).
KB_ADMIN_TOKEN=

# Override the OpenAI model used for grounded answer generation (default in code).
# OPENAI_MODEL=gpt-4o-mini

# Wiki/BM25 relevance gate (default 0.5). Read once at startup; restart to apply.
# KB_SCORE_THRESHOLD=0.5

# Per-language CJK relevance gate (interim, issue #261). Read once at startup;
# restart to apply. (The per-query part is only WHICH gate applies — CJK queries
# use this, others use KB_SCORE_THRESHOLD — the value itself is read at startup.)
# KB_SCORE_THRESHOLD_ZH=4.0
